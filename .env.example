APP_NAME=SentinelPilot
DATABASE_URL=sqlite:///./sentinel_pilot.db

IM_PROVIDER=dingtalk
IM_NOTIFICATION_ENABLED=false

# Optional legacy DingTalk webhook fallback.
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=

# DingTalk interactive card approval.
# Keep real values in local .env only. Do not commit secrets.
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_ROBOT_CODE=
DINGTALK_OPEN_CONVERSATION_ID=
DINGTALK_CARD_TEMPLATE_ID=
DINGTALK_CARD_CALLBACK_URL=
DINGTALK_CARD_CALLBACK_SECRET=

PUBLIC_APP_URL=http://localhost:3000
