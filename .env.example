APP_NAME=SentinelPilot
DATABASE_URL=sqlite:///./sentinel_pilot.db

IM_PROVIDER=dingtalk
IM_NOTIFICATION_ENABLED=false

# Robot notification channels. Pick one: dingtalk, feishu, or wecom.
# Keep real values in local .env only. Do not commit secrets.
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=
FEISHU_WEBHOOK_URL=
FEISHU_SECRET=
WECOM_WEBHOOK_URL=

# DingTalk interactive card approval.
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_ROBOT_CODE=
DINGTALK_OPEN_CONVERSATION_ID=
DINGTALK_CARD_TEMPLATE_ID=
DINGTALK_CARD_CALLBACK_URL=
DINGTALK_CARD_CALLBACK_SECRET=

PUBLIC_APP_URL=http://localhost:3000

# Optional LLM integration.
# OpenAI-compatible providers can be customized with BASE_URL and MODEL.
# Keep API keys in local .env only. Do not commit secrets.
LLM_ENABLED=false
LLM_PROVIDER=mock
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=30
LLM_PROMPT_PROFILE=default
# recommend_only | approval_required | auto_approve_simulated
LLM_ACTION_MODE=approval_required
LLM_ALLOW_HIGH_RISK_ACTIONS=true
